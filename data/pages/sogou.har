 {\n        this.style.backgroundColor = '';\n      };\n    }\n    var hintAbtest = '';\n\n    function sendPb(cltype, type, stype, extra) {\n      var pbsrc = location.protocol + '//pb.sogou.com/' + cltype + '.gif?uigs_productid=webapp&uigs_t=' + new Date().getTime();\n      pbsrc += '&uuid=' + (typeof window.uuid == 'undefined' ? '' : window.uuid);\n      pbsrc += '&type=' + type;\n      pbsrc += '&stype=' + stype;\n      pbsrc += '&abtest=' + hintAbtest;\n      if (typeof extra != 'undefined') {\n        pbsrc += extra;\n      }\n\n      new Image().src = pbsrc;\n    }\n\n    var stableUphint = $('#stable_uphint');\n    var dataShowed = 'data-showed';\n    var resultPage = 'resultpage';\n    var isUphintTag = stableUphint && stableUphint.attr('data-tag') ? stableUphint.attr('data-tag') : '0';\n    var upHintTag = '&isUpintTag=' + isUphintTag;\n\n    if (stableUphint) {\n      hintAbtest = stableUphint.attr('data-abtest');\n      stableUphint.attr(dataShowed, '0');\n      stableUphint.on('click', 'a', function (e) {\n        sendPb('cl', e.target.dataset.tag, resultPage, upHintTag);\n      });\n      $('#float_uphint').on('click', 'a', function (e) {\n        sendPb('cl', e.target.dataset.tag, resultPage, upHintTag);\n      });\n    }\n\n    if (isUphintTag == '1') {\n      stableUphint.attr(dataShowed, '1');\n      sendPb('pv', 'uphint', resultPage, upHintTag);\n    }\n\n    // function debounce(func, wait) {\n    //   var timeout = null;\n    //   return function () {\n    //     clearTimeout(timeout);\n    //     timeout = setTimeout(function () {\n    //       func.apply(this, arguments);\n    //     }, wait);\n    //   };\n    // }\n\n    function throttle(fn, interval) {\n      var canRun = true;\n      return function () {\n        var functionArguments = arguments;\n        if (!canRun) return;\n        canRun = false;\n        setTimeout(function () {\n          fn.apply(this, functionArguments);\n          canRun = true;\n        }, interval);\n      };\n    }\n\n    var whiteText = 'white-text';\n    var isWhiteText = $('body').hasClass(whiteText);\n    function checkFullTop(scrolltop) {\n      isWhiteText = isWhiteText || $('body').attr('iswhite');\n      var $fulltopvr = $('#fulltopvr');\n      if (!$fulltopvr.length) return;\n      var $header = $('.header');\n      var fulltopvrScroll = $fulltopvr.offset().top + $fulltopvr.innerHeight() - $header.outerHeight();\n      if (scrolltop > fulltopvrScroll) {\n        $header.removeClass('fulltop-bg');\n        $('body').removeClass(whiteText);\n      } else {\n        $header.addClass('fulltop-bg');\n        if (isWhiteText) {\n          $('body').addClass(whiteText);\n        }\n      }\n    }\n\n    // 增加实验isHeaderExp\n    var expInfo = window.SgConst?.common?.expinfoHits || [];\n    var headerParam = expInfo.find(item => item.params && item.params.front_129248047)?.params?.front_129248047;\n    var isHeaderExp = headerParam === '2' || headerParam === '3' || headerParam === '4';\n    const topBgInfo = $('.fulltop-bg');\n\n    function onscroll() {\n      if (!inited) {\n        $s.wait('searchForm', init);\n        return;\n      }\n\n      scrolltop = getstop();\n      if (Math.abs(oldtop - scrolltop) <= 4) {\n        return;\n      }\n\n      if (isHeaderExp && !topBgInfo) {\n        onscrollExp();\n        return;\n      }\n\n      checkFullTop(scrolltop);\n      var isMoveUp = false;// 是否向上滚动\n      var isShowUpHint = $s.$('float_uphint') && $s.$('stable_uphint');// 如果有顶部hint就默认为显示\n      if (isShowUpHint) {\n        isMoveUp = scrolltop < oldtop;// 当前滚动的高度小于上次滚动的高度\n      }\n\n      oldtop = scrolltop;\n      var tmp = -1;\n\n      if (scrolltop >= showForm) {\n        if (div.className.indexOf('headsearch') < 0) {\n          tmp = 1;\n        } else {\n          tmp = isMoveUp ? 2 : 1;// tmp=1:向下移动，有浮动搜索框但没有浮动的uphint；tmp=2:向上移动，有浮动搜索框也有浮动的uphint\n        }\n      } else {\n        if (div.className.indexOf('headsearch') >= 0) {\n          tmp = 0;// tmp=0:没有有浮动搜索框（当然也没有浮动的uphint）\n        }\n      }\n\n      if (tmp > -1) {\n        // childs = div.childNodes;\n        if (tmp > 0) {\n          var winHeight = window.innerHeight || ((document.body) && (document.body.clientHeight));\n          if (winHeight == document.body.offsetHeight && document.documentElement && document.documentElement.offsetHeight) {\n            winHeight = document.documentElement.offsetHeight;\n          }\n          if (winHeight && document.body.offsetHeight - winHeight < 50) {\n            return;\n          }\n          $(div).addClass('headsearch');\n          form.className = 'hsform';\n          if (isShowUpHint) {\n            if (tmp == 1) {\n              var tag = $s.$('float_uphint').dataset.tag;\n              if (tag === 'uphintTag') {\n                $s.$('float_uphint').style.display = 'block';\n              } else {\n                $s.$('float_uphint').style.display = 'none';\n              }\n\n              $s.$('stable_uphint').style.visibility = 'hidden';\n              // $s.$(\"stable_uphint\").style.display = \"none\";\n              if (scrolltop - getstop() == 31) { // 元素隐藏导致页面滚动高度发生变化，主动滚动到用户之前的位置\n                $(window).scrollTop(scrolltop);\n              };\n            } else if (tmp == 2) {\n              $s.$('float_uphint').style.display = '';\n              // $s.$(\"stable_uphint\").style.display = \"none\";\n              $s.$('stable_uphint').style.visibility = 'hidden';\n              if (scrolltop - getstop() == 31) {\n                $(window).scrollTop(scrolltop);\n              };\n              if (stableUphint.attr(dataShowed) == '0') {\n                sendPb('pv', 'uphint', resultPage, upHintTag);\n                stableUphint.attr(dataShowed, '1');\n              }\n              // 存在曝光函数时上报，避免有报错\n              if (window.HINTVIEWPORT && typeof window.HINTVIEWPORT.exposeTopHintReportHandler === 'function') {\n                window.HINTVIEWPORT.exposeTopHintReportHandler($('#float_uphint'));\n              }\n            }\n          }\n        } else {\n          $(div).removeClass('headsearch');\n          form.className = '';\n          if (isShowUpHint) {\n            $s.$('float_uphint').style.display = 'none';\n\n            // $s.$(\"stable_uphint\").style.display = \"\";\n            $s.$('stable_uphint').style.visibility = 'visible';\n            if (getstop() - scrolltop == 31) {\n              $(window).scrollTop(scrolltop);\n            };\n            if (stableUphint.attr(dataShowed) == '0') {\n              sendPb('pv', 'uphint', resultPage, upHintTag);\n              stableUphint.attr(dataShowed, '1');\n            }\n          }\n        }\n        if ($s.$('upquery')) {\n          $s.$('upquery').value = $s.$('upquery').value;// ??\n        }\n        if ($s.$('vl')) {\n          $s.$('vl').style.display = 'none';\n          $s.cls($s.$('querybox_up'), 'sugg-open');\n        }\n      }\n    }\n\n    function onscrollExp() {\n      const scrolltop = $(window).scrollTop();\n      checkFullTop(scrolltop);\n      // 修复：使用类选择器获取lineExp元素\n      var linePos = $('.lineExp');\n\n      console.log('scrolltop:', scrolltop);\n      if (scrolltop >= 22) {\n        linePos.addClass('lineExpFixed');\n        console.log('添加lineExpFixed类名 - lineExp开始悬浮');\n      } else {\n        linePos.removeClass('lineExpFixed');\n      }\n    }\n\n    $s.$b(window, ['scroll', 'resize'], [throttle(onscroll, 10), throttle(onscroll, 10)]);\n    $(window).on('scroll', throttle(onscrollExp, 50));\n    setTimeout(onscroll, 50);\n    setTimeout(onscrollExp, 50);\n  }());\n});\n  </script><div class=\"bg-gj-w\" id=\"settings-mask\" style=\"display: none;\"></div><div class=\"gjss\" id=\"settings-advanced\" style=\"display: none;top:-240px;\"><div class=\"hf-box\" id=\"settings-save-layer\"><div class=\"hf-def\">已保存设置</div></div><div class=\"gjss-tab\"><a uigs-id=\"tab_adv\" href=\"javascript:void(0);\" class=\"js-settings-tab tab-a\">高级搜索</a><a href=\"javascript:void