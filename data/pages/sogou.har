"bottom_qreset\" href=\"#\"></a></div></div></div><!-- BottomFormEnd -->  <!-- CopyRightViewBegin --><div class=\"cr\" id=\"s_footer\" style=\"\"><div><a id=\"sogou_feedback\" href=\"javascript:dissatisfied('fankuiform', false)\">意见反馈及投诉</a><a target=\"_blank\" id=\"sogou_jubao\" href=\"https://fankui.sogou.com/index.php/web/web/index/type/5?query=OpenClaw\">举报</a><a target=\"_blank\" id=\"sogou_weibo\" href=\"https://weibo.com/sogou\">官方微博</a><a id=\"sogou_mianze\" href=\"http://www.sogou.com/docs/terms.htm?v=1\" target=\"_blank\" class=\"g\">免责声明</a><a target=\"_blank\" id=\"sogou_private\" href=\"https://www.sogou.com/docs/privacy.htm?v=1\">隐私政策</a>&nbsp;&copy; 2026&nbsp;SOGOU.COM</div></div><!-- CopyRightViewEnd --> </div><!-- MainBodyViewEnd --> <!-- BottomViewBegin opt --> <img style=\"position:absolute;top:-1px\" src=\"/img/fav.ico?bfb4f8a3-730a-4131-ae26-64ce39dda618\" height=\"0\" border=\"0\" width=\"0\"><!-- vr external js--><!-- vr external js end--><script crossorigin=\"anonymous\" src=\"//search.sogoucdn.com/websearch/pc/static/js/searchBox.db8a3201.js\"></script><script crossorigin=\"anonymous\" src=\"//search.sogoucdn.com/websearch/pc/static/js/main.c418506a.js\"></script><script crossorigin=\"anonymous\" type=\"text/javascript\" src=\"//dlweb.sogoucdn.com/pcsearch/js/abtest_common_B.min_c93f4cb.js\"></script><form id=\"tupufankuiform\" method=\"post\" accept-charset=\"utf-8\"><input type=\"hidden\" name=\"cause\" value=\"\"> <input type=\"hidden\" name=\"query\" value=\"OpenClaw\"> <input type=\"hidden\" name=\"refer\" value=\"https://sogou.com/\"> <input type=\"hidden\" name=\"uuid\" value=\"bfb4f8a3-730a-4131-ae26-64ce39dda618\"> <input type=\"hidden\" name=\"scenehtml\" value=\"\" id=\"tupuscenehtml\"> <input type=\"hidden\" name=\"queryurl\" value=\"\"> <input type=\"hidden\" name=\"content\" value=\"\"> <input type=\"hidden\" name=\"side\" value=\"\"> <input type=\"hidden\" name=\"product\" value=\"\"> <input type=\"hidden\" name=\"vrid\" value=\"\"></form>   <script type=\"text/javascript\">/*file=static/js/extQuery.js*/'use strict';\n\ndefine('', ['$', '$s'], function ($, $s) {\n  if (window.unlimitedQuery_var) {\n    return;\n  }\n  var sgparam = window.SgConst.common;\n  if (sgparam.disableClickSugg) {\n    return;\n  }\n\n  var DOC_URL_LIMIT = 10;\n  var ALL_URL_LIMIT = 50;\n\n  function clickTitleLog(sugQueryElement, sugQuerys, rank, classId, extSite) {\n    if (sugQueryElement.length <= 0) {\n      return;\n    }\n\n    var sugQuery = [];\n\n    for (var i = 0; i < sugQuerys.length; i++) {\n      sugQuery.push(sugQuerys[i].query);\n    }\n\n    sugQuery = sugQuery.join(';');\n    displayDelay(sugQueryElement);\n    var nowDate = new Date().getTime();\n    var params = [];\n    var uigsPara = window.uigs_para;\n    params.push('uigs_productid=' + uigsPara.uigs_productid);\n    params.push('uigs_t=' + nowDate);\n    params.push('uigs_cookie=' + encodeURIComponent(uigsPara.uigs_cookie));\n    params.push('uuid=' + encodeURIComponent(uigsPara.uuid));\n    params.push('top=' + rank);\n    params.push('sug_query_log=1');\n    params.push('vrid=' + classId);\n    params.push('abtestid=' + encodeURIComponent(uigsPara.abtestid));\n    params.push('query=' + encodeURIComponent(uigsPara.query));\n    params.push('extSite=' + extSite);\n    params.push('sug_query=' + (sugQuery ? encodeURIComponent(sugQuery) : ''));\n    params.push('uigs_refer=' + encodeURIComponent(window.location.href));\n    sendClPingBack(params);\n  }\n\n  function getScreen() {\n    var sc = window.screen || {};\n    var width = sc.width;\n    var height = sc.height;\n    var devicePixelRatio = window.devicePixelRatio || 1;\n    var screenResolutionWidth = width * devicePixelRatio;\n    var screenResolutionHeight = height * devicePixelRatio;\n\n    if (screenResolutionWidth && screenResolutionHeight) {\n      return screenResolutionWidth + '*' + screenResolutionHeight;\n    }\n  }\n\n  function clickQueryLog(sugQueryUrl, extQuery, rank, classId, extSite) {\n    var nowDate = new Date().getTime();\n    var params = [];\n    var uigsPara = window.uigs_para;\n    params.push('uigs_productid=' + uigsPara.uigs_productid);\n    params.push('uigs_t=' + nowDate);\n    params.push('uigs_cookie=' + encodeURIComponent(uigsPara.uigs_cookie));\n    params.push('uuid=' + encodeURIComponent(uigsPara.uuid));\n    params.push('uigs_sug_refer=' + encodeURIComponent(sugQueryUrl));\n    params.push('top=' + rank);\n    params.push('sug_query_log=2');\n    params.push('vrid=' + classId);\n    params.push('abtestid=' + encodeURIComponent(uigsPara.abtestid));\n    params.push('query=' + encodeURIComponent(uigsPara.query));\n    params.push('extSite=' + extSite);\n\n    if (extQuery) {\n      params.push('sug_query=' + encodeURIComponent(extQuery));\n    }\n\n    params.push('uigs_refer=' + encodeURIComponent(window.location.href));\n    sendClPingBack(params);\n  }\n\n  function sendClPingBack(argList) {\n    var urlAndParam = $s.httpsUtil.getPingbackHost() + '/cl.gif';\n\n    for (var i = 0; i < argList.length; i++) {\n      if (i == 0) {\n        urlAndParam = urlAndParam + '?' + argList[i];\n      } else {\n        urlAndParam = urlAndParam + '&' + argList[i];\n      }\n    }\n\n    new Image().src = urlAndParam;\n  }\n\n  // 生成posId的参数\n  function generateInheritParams() {\n    if (!window.inheritParams) {\n      return '';\n    }\n\n    var inheritParams = window.inheritParams;\n    var inheritUrlParam = '';\n    for (var key in inheritParams) {\n      inheritUrlParam += '&' + key + '=' + encodeURIComponent(inheritParams[key]);\n    }\n\n    return inheritUrlParam;\n  }\n\n  function createExtLink(fragment, extQueryIdTexts, extQueryObj, classid, rank, index, expSugg) {\n    var aTagId = extQueryIdTexts[0] + '_' + extQueryIdTexts[1] + '_30010469_' + rank + '_sq_ext_a_' + index;\n    var uigsPara = window.uigs_para;\n    var extQuery = extQueryObj.query;\n    var sugQueryUrl = '?query=' + encodeURIComponent(extQuery) + '&ie=utf8&s_from=extquery&duppid=1&pid=' + uigsPara.pid + generateInheritParams();\n    var aTag = $('<a/>');\n    aTag\n      .attr({\n        target: window.globalConfig && window.globalConfig.iSQBotAIPage ? '' : '_blank',\n        href: sugQueryUrl,\n        id: aTagId,\n      })\n      .text(extQuery)\n      .bind('click', function () {\n        clickQueryLog(sugQueryUrl, extQuery, rank, classid, 'ext');\n      });\n    fragment.appendChild(expSugg ? $('<span></span>').append(aTag)[0] : aTag[0]);\n  }\n\n  function reBuild($extQuery, sugQuerys, rank, classid, extQueryIdTexts) {\n    var wordNum = 0;\n    var fragment = document.createDocumentFragment();\n\n    for (var i = 0; i < sugQuerys.length; i++) {\n      if (sugQuerys[i] && i < 10) {\n        wordNum += 1;\n        createExtLink(fragment, extQueryIdTexts, sugQuerys[i], classid, rank, i, $extQuery.hasClass('click-better-sugg'));\n      }\n    }\n\n    $extQuery\n      .find('p')\n      .append(fragment);\n    return wordNum;\n  }\n\n  function displayNoneOther(rank) {\n    $('.r-sech.ext_query').each(function () {\n      var eachId = $(this).attr('id');\n      var eachIds = eachId.split('_');\n      var eachIdsLength = eachIds.length;\n      var eachRank = eachIds[eachIdsLength - 1];\n\n      if (rank != eachRank) {\n        $(this).css('display', 'none');\n      }\n    });\n\n    $('.r-sech.ad_ext_query').each(function () {\n      $(this).css('display', 'none');\n    });\n  }\n\n  function displayDelay($ele) {\n    if (!$ele) {\n      return;\n    }\n\n    // ie直接展示\n    if (!!window.ActiveXObject || 'ActiveXObject' in window) {\n      $ele.css('display', '');\n    }\n    // 需要展现当前节点（防止同时展现多个结果的推荐）\n    $ele.data('needshow', '1');\n    var hidden;\n    var visibilityChange;\n\n    if (typeof document.hidden !== 'undefined') {\n      // Opera 12.10 and Firefox 18 and later support\n      hidden = 'hidden';\n      visibilityChange = 'visibilitychange';\n    } else if (typeof document.msHidden !== 'undefined') {\n      hidden = 'msHidden';\n      visibilityChange = 'msvisibilitychange';\n    } else if (typeof document.webkitHidden !== 'undefined') {\n      hidden = 'webkitHidden';\n      visibilityChange = 'webkitvisibilitychange';\n    }\n\n    var onVisibilityChange = function onVisibilityChange() {\n      if (!document[hidden] && $ele.css('display') == 'none') {\n        if ($ele.data('needshow') == '1') {\n          $ele.slideToggle();\n          window.HINTVIEWPORT && window.HINTVIEWPORT.showSuggReport($ele);\n        }\n\n        $(document).off(visibilityChange, onVisibilityChange);\n      }\n    };\n\n    if (visibilityChange) {\n      if ($ele.css('display') == 'none') {\n        $(document).on(visibilityChange, onVisibilityChange);\n      }\n    } else {\n      $ele.css('display', '');\n      window.HINTVIEWPORT && window.HINTVIEWPORT.showSuggReport($ele);\n    }\n  }\n\n  function dealAdExt($extQuery, sugQuerys, rank, classid, extQueryIdTexts) {\n    var preAdResult = $extQuery.parent('.biz_rb');\n\n    if (preAdResult) {\n      preAdResult\n        .find('h3.biz_title a')\n        .first()\n        .on('click', function () {\n          var wordNum = reBuild($extQuery, sugQuerys, rank, classid, extQueryIdTexts);\n\n          if (wordNum > 0) {\n            clickTitleLog($extQuery, sugQuerys, rank, classid, 'ext');\n          }\n\n          displayNoneOther(rank);\n        });\n    }\n  }\n\n  function getResult($extQuery) {\n    var $result = $extQuery.closest('.rb');\n\n    if ($result.length == 0) {\n      $result = $extQuery.closest('.vrwrap');\n    }\n\n    return $result;\n  }\n\n  function addSet(arr, item) {\n    if ($.inArray(item, arr) === -1) {\n      arr.push(item);\n    }\n  }\n\n  // 判断url是否有效\n  function validUrl(url) {\n    return url && url.indexOf('javascript') !== 0 && url.indexOf('/link?') !== 0;\n  }\n\n  function getUrlInfo($link) {\n    var url = $link.attr('href');\n\n    if (url && validUrl(url)) {\n      return url;\n    }\n  }\n\n  function getValidInfo($doc, $extQuery) {\n    if ($extQuery.data('normal')) {\n      return $extQuery.data('url');\n    }\n\n    // 通用title的链接\n    var urlInfo = getUrlInfo($doc.find('a.vr-title'));\n    if (urlInfo) {\n      return urlInfo;\n    }\n\n    var links = $doc.find('a[href]');\n\n    for (var i = 0; i < links.length; i++) {\n      urlInfo = getUrlInfo(links.eq(i));\n\n      if (urlInfo) {\n        return urlInfo;\n      }\n    }\n\n    return $extQuery.data('url');\n  }\n\n  function getDocUrls($doc, limit) {\n    limit = limit || 1;\n    var urls = [];\n\n    if (!$doc) {\n      return urls;\n    }\n\n    $doc.find('a[href]').each(function (i, e) {\n      if (urls.length >= limit) {\n        return;\n      }\n\n      var $e = $(e);\n      var id = $e.attr('id');\n\n      if (id && id.indexOf('uigs_ext_') === 0) {\n        // 忽略点后推链接\n        return;\n      }\n\n      var href = $e.attr('href');\n\n      if (validUrl(href)) {\n        addSet(urls, href);\n      }\n    });\n    return urls;\n  }\n\n  function getUrls($extQuery) {\n    var urls = [];\n    $('.ext_query').each(function (_, e) {\n      if (urls.length >= ALL_URL_LIMIT) {\n        return;\n      }\n\n      var $e = $(e);\n\n      if ($e.attr('id') === $extQuery.attr('id')) {\n        return;\n      }\n\n      var $doc = getResult($e);\n\n      if (!$doc || $doc.length === 0) {\n        return;\n      }\n\n      var dataUrl = $e.data('url');\n\n      if ($e.data('normal') && dataUrl) {\n        addSet(urls, dataUrl);\n        return;\n      }\n\n      var docUrls = getDocUrls($doc, DOC_URL_LIMIT);\n\n      if (docUrls && docUrls.length >= 1) {\n        urls = urls.concat(docUrls);\n        return;\n      }\n\n      if (dataUrl) {\n        addSet(urls, dataUrl);\n      }\n    });\n    return urls.slice(0, ALL_URL_LIMIT);\n  }\n\n  function getSuburls($doc, $extQuery) {\n    if ($extQuery.data('normal')) {\n      return [];\n    }\n\n    return getDocUrls($doc, DOC_URL_LIMIT);\n  }\n\n  function getDocInfo($extQuery, $result) {\n    var url;\n\n    if ($result) {\n      url = getValidInfo($result, $extQuery);\n    }\n\n    var urls = getUrls($extQuery);\n    var suburls = getSuburls($result, $extQuery);\n    return {\n      urls: urls,\n      suburls: suburls,\n      url: url || $extQuery.data('url') || '',\n      docId: $extQuery.data('docid'),\n    };\n  }\n\n  function clickSugg(docInfo) {\n    var query = window.oldQuery;\n    var param = window.SgConst.common;\n    var expinfo = param.expinfoHits || [];\n    var uigsPara = window.uigs_para || {};\n    var ua = window.navigator.userAgent;\n    var uuid = uigsPara.uuid;\n    var wuid = $s.cookie('SUV');\n    var pidChannel = param.pidChannel || [];\n\n    return $.ajax({\n      type: 'POST',\n      url: 'https://sor.html5.qq.com/rsproxy/PCFeedback',\n      data: JSON.stringify($.extend(\n        {\n          uuid: uuid,\n          wuid: wuid,\n          userArea: param.userarea,\n          search_time: window.now,\n          query: query,\n          abtest: param.sab,\n          ua: ua,\n          pid: param.pid,\n          first_channel: pidChannel[0] || '',\n          second_channel: pidChannel[1] || '',\n          third_channel: pidChannel[2] || '',\n          trafficSign: 'web',\n          from: 'ajax',\n          front_screen_resolution: getScreen(),\n          isWaigou: param.pidType,\n          expinfo: JSON.stringify(expinfo),\n        },\n        docInfo,\n      )),\n      contentType: 'application/json',\n      dataType: 'json',\n    });\n  }\n\n  function asyncClickSuggHandle($extQuery, classid, rank, extQueryIdTexts) {\n    var $result = getResult($extQuery);\n\n    if ($result.length == 0) {\n      return;\n    }\n\n    var promise;\n    $result.on('click', 'a', function (ev) {\n      if (!promise) {\n        var docInfo = getDocInfo($extQuery, $result);\n        promise = clickSugg(docInfo);\n      }\n\n      promise.done(function (ret) {\n        var $a = $(ev.target).closest('a');\n\n        if (ret && ret.list && ret.list.length) {\n          displayExtQuery($extQuery, $a, ret.list, rank, classid, extQueryIdTexts);\n        }\n      });\n    });\n  }\n\n  function clickSuggHandle($extQuery, classid, rank, extQueryIdTexts) {\n    var extQueryAId = extQueryIdTexts[0] + '_' + extQueryIdTexts[1] + '_' + classid + '_sq_ext_a_' + rank;\n    var $extA = $('#' + extQueryAId);\n    var ext = $extA.text();\n\n    if (ext == '') {\n      return true;\n    }\n\n    $extA.remove();\n    var sugQueryList = ext.replace(/；/g, ';').split(';');\n    var sugQuerys = [];\n\n    for (var i = 0; i < sugQueryList.length; i++) {\n      if (sugQueryList[i]) {\n        sugQuerys.push({\n          query: sugQueryList[i],\n        });\n      }\n    }\n    // 广告的rank>10000\n    if (rank >= 10000) {\n      dealAdExt($extQuery, sugQuerys, rank, classid, extQueryIdTexts);\n      return;\n    }\n    // 修改为title和子链都可以展示点击推荐\n    // 1.寻找每条结果的外层div\n    var $result = getResult($extQuery);\n\n    if ($result.length == 0) {\n      return;\n    }\n\n    $result.on('click', 'a', function (ev) {\n      var $a = $(ev.target).closest('a');\n      displayExtQuery($extQuery, $a, sugQuerys, rank, classid, extQueryIdTexts);\n    });\n  }\n\n  function displayExtQuery($extQuery, $a, sugQuerys, rank, classid, extQueryIdTexts) {\n    var wordNum;\n    if ($extQuery.data('render')) {\n      wordNum = $extQuery.data('wordNum');\n    } else {\n      wordNum = reBuild($extQuery, sugQuerys, rank, classid, extQueryIdTexts);\n      $extQuery.data('render', 1);\n      $extQuery.data('wordNum', wordNum);\n    }\n\n    if (/javascript:\\s*void\\s*\\(\\s*0\\s*\\)/.test($a.attr('href'))) {\n      return;\n    }\n\n    if (wordNum > 0) {\n      clickTitleLog($extQuery, sugQuerys, rank, classid, 'ext');\n    }\n\n    displayNoneOther(rank);\n  }\n\n  function extQueryInit() {\n    // 初始化\n    $('.ext_query').each(function () {\n      var $extQuery = $(this);\n\n      // 跳过已经初始化的元素\n      if ($extQuery.attr('init') === '1') {\n        return;\n      }\n\n      var extQueryIdText = $extQuery.attr('id');\n      var extQueryIdTexts = extQueryIdText.split('_');\n      var extQueryIdTextsLength = extQueryIdTexts.length;\n\n      if (extQueryIdTextsLength < 2) {\n        return;\n      }\n\n      var classid = extQueryIdTexts[2];\n      var rank = extQueryIdTexts[extQueryIdTextsLength - 1];\n      var async = $extQuery.data('async');\n\n      if (async) {\n        asyncClickSuggHandle($extQuery, classid, rank, extQueryIdTexts);\n      } else {\n        clickSuggHandle($extQuery, classid, rank, extQueryIdTexts);\n      }\n\n      // 标记为已初始化\n      $extQuery.attr('init', '1');\n    });\n  }\n  window.extQueryInit = extQueryInit;\n  extQueryInit();\n});\n</script>  <script type=\"text/javascript\">/*file=static/js/extQueryForAd.js*/'use strict';\n\ndefine('', ['$', '$s'], function ($, $s) {\n  var ua = window.navigator.userAgent || '';\n  var isQB = ua.toLowerCase().includes('qqbrowser');\n  var isSogou = ua.toLowerCase().includes('metasr');\n\n  if (!isQB && !isSogou) {\n    return;\n  }\n\n  var param = window.SgConst.common;\n  if (param.disableClickSugg) {\n    return;\n  }\n  var expinfo = param.expinfoHits || [];\n  var expRsParam = expinfo.find(item => item.params && item.params.ad_result_ext_query);\n  var expRsswitch = false;\n  if (expRsParam && expRsParam.params) {\n    expRsswitch = expRsParam.params.ad_result_ext_query === '1';\n  }\n\n  if (!expRsswitch) {\n    return;\n  }\n\n  if (window.unlimitedQuery_var) {\n    return;\n  }\n\n  var AD_EXT_QUERY_CLASS = '.ad_ext_query';\n\n  function clickTitleLog(sugQueryElement, sugQuerys, rank, classId, extSite) {\n    if (sugQueryElement.length <= 0) {\n      return;\n    }\n\n    var sugQuery = [];\n\n    for (var i = 0; i < sugQuerys.length; i++) {\n      sugQuery.push(sugQuerys[i].query);\n    }\n\n    sugQuery = sugQuery.join(';');\n    displayDelay(sugQueryElement);\n    var nowDate = new Date().getTime();\n    var params = [];\n    var uigsPara = window.uigs_para;\n    params.push('uigs_productid=' + uigsPara.uigs_productid);\n    params.push('uigs_t=' + nowDate);\n    params.push('uigs_cookie=' + encodeURIComponent(uigsPara.uigs_cookie));\n    params.push('uuid=' + encodeURIComponent(uigsPara.uuid));\n    params.push('top=' + rank);\n    params.push('sug_query_log=1');\n    params.push('vrid=' + classId);\n    params.push('abtestid=' + encodeURIComponent(uigsPara.abtestid));\n    params.push('query=' + encodeURIComponent(uigsPara.query));\n    params.push('extSite=' + extSite);\n    params.push('sug_query=' + (sugQuery ? encodeURIComponent(sugQuery) : ''));\n    params.push('uigs_refer=' + encodeURIComponent(window.location.href));\n    sendClPingBack(params);\n  }\n\n  function clickQueryLog(sugQueryUrl, extQuery, rank, classId, extSite) {\n    var nowDate = new Date().getTime();\n    var params = [];\n    var uigsPara = window.uigs_para;\n    params.push('uigs_productid=' + uigsPara.uigs_productid);\n    params.push('uigs_t=' + nowDate);\n    params.push('uigs_cookie=' + encodeURIComponent(uigsPara.uigs_cookie));\n    params.push('uuid=' + encodeURIComponent(uigsPara.uuid));\n    params.push('uigs_sug_refer=' + encodeURIComponent(sugQueryUrl));\n    params.push('top=' + rank);\n    params.push('sug_query_log=2');\n    params.push('vrid=' + classId);\n    params.push('abtestid=' + encodeURIComponent(uigsPara.abtestid));\n    params.push('query=' + encodeURIComponent(uigsPara.query));\n    params.push('extSite=' + extSite);\n\n    if (extQuery) {\n      params.push('sug_query=' + encodeURIComponent(extQuery));\n    }\n\n    params.push('uigs_refer=' + encodeURIComponent(window.location.href));\n    sendClPingBack(params);\n  }\n\n  function getScreen() {\n    var sc = window.screen || {};\n    var width = sc.width;\n    var height = sc.height;\n    var devicePixelRatio = window.devicePixelRatio || 1;\n    var screenResolutionWidth = width * devicePixelRatio;\n    var screenResolutionHeight = height * devicePixelRatio;\n\n    if (screenResolutionWidth && screenResolutionHeight) {\n      return screenResolutionWidth + '*' + screenResolutionHeight;\n    }\n  }\n\n  function sendClPingBack(argList) {\n    var urlAndParam = $s.httpsUtil.getPingbackHost() + '/cl.gif';\n\n    for (var i = 0; i < argList.length; i++) {\n      if (i == 0) {\n        urlAndParam = urlAndParam + '?' + argList[i];\n      } else {\n        urlAndParam = urlAndParam + '&' + argList[i];\n      }\n    }\n\n    new Image().src = urlAndParam;\n  }\n\n  function amsExpInfo(expinfo) {\n    let expIds = [];\n    if (expinfo) {\n      expIds = expinfo\n        .map(exp => exp.params?.sogou_ams)\n        .filter(sogouAms => sogouAms !== undefined && sogouAms !== null && sogouAms !== '');\n    }\n    expIds.push('194219-1');\n    const info = {\n      exp_id: expIds,\n    };\n    return JSON.stringify(info);\n  }\n\n  function sendAttaLog(action, traceId, posId, showPos) {\n    var attaPageExposureParams = window.attaPageExposureParams || {};\n    var uuid = attaPageExposureParams.uuid || '';\n    var query = window.oldQuery || '';\n    var qimei36 = attaPageExposureParams.Q36 || '';\n    var guid = attaPageExposureParams.guid || '';\n    var ua = window.navigator.userAgent;\n    var qua = window.uigs_para.qua || '';\n    var param = window.SgConst.common;\n    var expinfo = param.expinfoHits || [];\n    var expId = amsExpInfo(expinfo);\n\n    var reportParams = {\n      action: action,\n      action_time: Date.now(),\n      uuid: uuid,\n      query: query,\n      ams_trace_id: traceId,\n      qimei36: qimei36,\n      guid: guid,\n      ams_postion_id: posId,\n      event_value: JSON.stringify({\n        exp_id: expId,\n        provider: 'adx_sogouad_pc',\n        search_show_pos: showPos,\n        qua: qua,\n        ua: ua,\n      }),\n    };\n\n    var inlongParams = {\n      groupId: 'gwe00032122367',\n      streamId: 'swe0000131273f',\n      reportUrl: 'https://trace.inlong.qq.com/hn0_csigcommon',\n      reportParams: reportParams,\n    };\n    if (window.QBInvoker && window.QBInvoker.sendInlongReport) {\n      window.QBInvoker.sendInlongReport(inlongParams);\n    }\n  }\n\n  function queryExposeLog() {\n    $(document).ready(function () {\n      const exposureStates = new WeakMap();\n\n      const observer = new IntersectionObserver(function (entries) {\n        if (document.hidden) {\n          return;\n        }\n\n        entries.forEach(function (entry) {\n          if (!exposureStates.has(entry.target)) {\n            exposureStates.set(entry.target, {\n              exposed: false,\n              halfExposed: false,\n            });\n          }\n          const state = exposureStates.get(entry.target);\n\n          const $target = $(entry.target);\n          const traceId = $target.data('traceid');\n          const posId = $target.data('posid');\n          const showPos = $target.data('showpos');\n\n          if (entry.isIntersecting && !state.exposed) {\n            sendAttaLog('rs_wide_expose', traceId, posId, showPos);\n            state.exposed = true;\n          }\n\n          if (entry.intersectionRatio >= 0.5 && !state.halfExposed) {\n            sendAttaLog('rs_expose', traceId, posId, showPos);\n            state.halfExposed = true;\n          }\n\n          if (state.exposed && state.halfExposed) {\n            observer.unobserve(entry.target);\n          }\n        });\n      }, {\n        threshold: [0, 0.5],\n      });\n\n      $(AD_EXT_QUERY_CLASS).each(function () {\n        observer.observe(this);\n      });\n    });\n  }\n\n  // 生成posId的参数\n  function generateInheritParams() {\n    if (!window.inheritParams) {\n      return '';\n    }\n\n    var inheritParams = window.inheritParams;\n    var inheritUrlParam = '';\n    for (var key in inheritParams) {\n      inheritUrlParam += '&' + key + '=' + encodeURIComponent(inheritParams[key]);\n    }\n\n    return inheritUrlParam;\n  }\n\n  function createExtLink(fragment, extQueryIdTexts, extQueryObj, classid, rank, index, expSugg) {\n    var aTagId = extQueryIdTexts[0] + '_' + extQueryIdTexts[1] + '_30010571_' + rank + '_sq_ext_a_' + index;\n    var uigsPara = window.uigs_para;\n    var extQuery = extQueryObj.query;\n    var sugQueryUrl = '?query=' + encodeURIComponent(extQuery) + '&ie=utf8&s_from=ad_hint&duppid=1&pid=' + uigsPara.pid + generateInheritParams();\n    var aTag = $('<a/>');\n    aTag\n      .attr({\n        target: window.globalConfig && window.globalConfig.iSQBotAIPage ? '' : '_blank',\n        href: sugQueryUrl,\n        id: aTagId,\n      })\n      .text(extQuery)\n      .bind('click', function () {\n        var $parent = $(this).closest(AD_EXT_QUERY_CLASS);\n        var traceId = $parent.data('traceid');\n        var posId = $parent.data('posid');\n        var showPos = $parent.data('showpos');\n        sendAttaLog('rs_click', traceId, posId, showPos);\n        clickQueryLog(sugQueryUrl, extQuery, rank, classid, 'ext');\n      });\n    fragment.appendChild(expSugg ? $('<span></span>').append(aTag)[0] : aTag[0]);\n  }\n\n  function reBuild(sqExtTextId, sugQuerys, rank, classid, extQueryIdTexts) {\n    var wordNum = 0;\n    var fragment = document.createDocumentFragment();\n\n    for (var i = 0; i < sugQuerys.length; i++) {\n      if (sugQuerys[i] && i < 10) {\n        wordNum += 1;\n        createExtLink(fragment, extQueryIdTexts, sugQuerys[i], classid, rank, i, $('#' + sqExtTextId).hasClass('click-better-sugg'));\n      }\n    }\n\n    $('#' + sqExtTextId)\n      .find('p')\n      .append(fragment);\n    return wordNum;\n  }\n\n  function displayNoneOther(rank) {\n    $('.r-sech.ad_ext_query').each(function () {\n      var eachId = $(this).attr('id');\n      var eachIds = eachId.split('_');\n      var eachIdsLength = eachIds.length;\n      var eachRank = eachIds[eachIdsLength - 1];\n\n      if (rank != eachRank) {\n        $(this).css('display', 'none');\n      }\n    });\n\n    $('.r-sech.ext_query').each(function () {\n      $(this).css('display', 'none');\n    });\n  }\n\n  function displayDelay($ele) {\n    if (!$ele) {\n      return;\n    }\n\n    // ie直接展示\n    if (!!window.ActiveXObject || 'ActiveXObject' in window) {\n      $ele.css('display', '');\n    }\n    // 需要展现当前节点（防止同时展现多个结果的推荐）\n    $ele.data('needshow', '1');\n    var hidden;\n    var visibilityChange;\n\n    if (typeof document.hidden !== 'undefined') {\n      // Opera 12.10 and Firefox 18 and later support\n      hidden = 'hidden';\n      visibilityChange = 'visibilitychange';\n    } else if (typeof document.msHidden !== 'undefined') {\n      hidden = 'msHidden';\n      visibilityChange = 'msvisibilitychange';\n    } else if (typeof document.webkitHidden !== 'undefined') {\n      hidden = 'webkitHidden';\n      visibilityChange = 'webkitvisibilitychange';\n    }\n\n    var onVisibilityChange = function onVisibilityChange() {\n      if (!document[hidden] && $ele.css('display') == 'none') {\n        if ($ele.data('needshow') == '1') {\n          $ele.slideToggle();\n          window.HINTVIEWPORT && window.HINTVIEWPORT.showSuggReport($ele);\n        }\n\n        $(document).off(visibilityChange, onVisibilityChange);\n      }\n    };\n\n    if (visibilityChange) {\n      if ($ele.css('display') == 'none') {\n        $(document).on(visibilityChange, onVisibilityChange);\n      }\n    } else {\n      $ele.css('display', '');\n      window.HINTVIEWPORT && window.HINTVIEWPORT.showSuggReport($ele);\n    }\n\n    queryExposeLog();\n  }\n\n  function getResult($extQuery) {\n    return $extQuery.closest('.ad_result');\n  }\n\n  function getAdTitle($element) {\n    var $result = getResult($element);\n\n    var $title = $result.find('.p-title-text');\n\n    return $title.text().trim();\n  }\n\n  function getAdContent($element) {\n    var $result = getResult($element);\n\n    var $content = $result.find('.p-desc');\n\n    return $content.text().trim();\n  }\n\n  function getAdKeyword($element) {\n    return $element.data('kw');\n  }\n\n  function clickSugg(title, content, keyword) {\n    var query = window.oldQuery;\n    var param = window.SgConst.common;\n    var expinfo = param.expinfoHits || [];\n    var uigsPara = window.uigs_para || {};\n    var ua = window.navigator.userAgent;\n    var uuid = uigsPara.uuid;\n    var wuid = $s.cookie('SUV');\n    var pidChannel = param.pidChannel || [];\n\n    sendAttaLog('rs_request');\n\n    return $.ajax({\n      type: 'POST',\n      url: 'https://sor.html5.qq.com/rsproxy/PCFeedback',\n      data: JSON.stringify({\n        uuid: uuid,\n        wuid: wuid,\n        userArea: param.userarea,\n        search_time: window.now,\n        query: query,\n        abtest: param.sab,\n        ua: ua,\n        pid: param.pid,\n        first_channel: pidChannel[0] || '',\n        second_channel: pidChannel[1] || '',\n        third_channel: pidChannel[2] || '',\n        trafficSign: 'web',\n        from: 'ajax',\n        front_screen_resolution: getScreen(),\n        isWaigou: param.pidType,\n        expinfo: JSON.stringify(expinfo),\n        title: title,\n        s_from: 'ad_hint',\n        other: {\n          ad_des: content,\n          hit_kw: keyword,\n        },\n      }),\n      contentType: 'application/json',\n      dataType: 'json',\n    });\n  }\n\n  function asyncClickSuggHandle($extQuery, classid, rank, extQueryIdTexts) {\n    var $result = getResult($extQuery);\n\n    if ($result.length == 0) {\n      return;\n    }\n\n    var promise;\n    $result.on('click', 'a', function (ev) {\n      if (!promise) {\n        var title = getAdTitle($extQuery);\n        var content = getAdContent($extQuery);\n        var keyword = getAdKeyword($extQuery);\n        promise = clickSugg(title, content, keyword);\n      }\n\n      promise.done(function (ret) {\n        var $a = $(ev.target).closest('a');\n\n        if (ret && ret.list && ret.list.length) {\n          displayExtQuery($extQuery, $a, $extQuery.attr('id'), ret.list, rank, classid, extQueryIdTe